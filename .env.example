# ─── Required ────────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooler endpoint recommended)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session encryption secret — generate with: npx auth secret
AUTH_SECRET=""

# ─── Auth: Email magic links (optional — skip if Google-only) ────────────────

# Resend API key (https://resend.com/api-keys)
# AUTH_RESEND_KEY=""

# Sender address — must match a verified domain in Resend.
# In Vercel env vars, do NOT wrap the value in quotes.
# AUTH_EMAIL_FROM="Finpath <noreply@yourdomain.com>"

# ─── Auth: Google OAuth (optional — skip if email-only) ──────────────────────

# Create at: Google Cloud Console > APIs & Services > Credentials > OAuth client
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Authorized redirect URIs to add in Google Cloud:
#   Production:  https://<your-domain>/api/auth/callback/google
#   Local dev:   http://localhost:3000/api/auth/callback/google
#
# Common pitfalls:
#   - Copy ID and Secret from the SAME OAuth client
#   - Do not double-paste (verify lengths match Google console values)
#   - In Vercel env UI, paste raw values — no surrounding quotes
#   - If consent screen is in "Testing" mode, add test user emails
